# Copy this file to .env and fill in real values before running docker compose.
# NEVER commit .env — it is gitignored.

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=scriptorium
POSTGRES_PASSWORD=changeme_strong_postgres_password
POSTGRES_DB=scriptorium

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_strong_redis_password

# ─── Web UI auth (single-user, no user-management system) ────────────────────
UI_USERNAME=admin
UI_PASSWORD=changeme_strong_ui_password

# JWT signing key — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_a_random_64_char_hex_string_here

# ─── Corpus ───────────────────────────────────────────────────────────────────
# Absolute path on the Docker host to your NFS-mounted corpus.
# Mounted :ro into every container that touches files.
CORPUS_PATH=/mnt/nas/documents

# ─── Networking ──────────────────────────────────────────────────────────────
# Port exposed on the host. Point your external Nginx at http://<vm-ip>:WEB_PORT
WEB_PORT=8000

# ─── Scanner ─────────────────────────────────────────────────────────────────
SCAN_INTERVAL=300
MISS_THRESHOLD=2
# When true (default), the scanner never removes documents from the index
# automatically, even if files are deleted or the NAS goes offline.
# Use the Admin page in the UI for intentional manual cleanup.
PRESERVE_CATALOG=true

# ─── OCR workers ─────────────────────────────────────────────────────────────
OCR_WORKER_COUNT=4
OCR_ENGINE=tesseract
